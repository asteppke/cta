# superposition ---------------------------------------------------------------
#
# We use superposition.db to logically or the outputs of all sequences.
# The output of all series 0 are ored, the output of all series 1 are ored and so on.
#
# The instances of superposition.db are chained together using the LNK makro.
# So processing the first instance, processes all of them.
#
# sequence 0
#    series 0 ----|          
#    series 1 ----|------|
#    series 2 ----|------|------|
#                 |      |      |
# sequence 1      |      |      |
#    series 0 ----|-|    |      |
#    series 1 ----|-|----|-|    |
#    series 2 ----|-|----|-|----|-|
#                 | |    | |    | |
#                 ---    ---    ---
#                 |#|    |#|    |#|
#                 ---    ---    --- 
#                  |      |      |
#                  |      |      |------ superpositioned series 2
#                  |      |------------- superpositioned series 1
#                  |-------------------- superpositioned series 0

file superposition.db {

  pattern
  {NAME,                     IN1, IN2,                              OUT,                              LNK,                         TRA}
  # series 0
  {$(SYS)-$(CTA):supSer0_0,  "0", "$(SYS)-$(CTA):seq0Ser0-Data-O",  "$(SYS)-$(EOS):Evt-1-Ena-Sel PP",  "$(SYS)-$(CTA):supSer1_0",  "$(TR=0)"} # sequence 0
  # series 1
  {$(SYS)-$(CTA):supSer1_0,  "0", "$(SYS)-$(CTA):seq0Ser1-Data-O",  "$(SYS)-$(EOS):Evt-2-Ena-Sel PP",  "$(SYS)-$(CTA):supSer2_0",  "$(TR=0)"} # sequence 0
  # series 2
  {$(SYS)-$(CTA):supSer2_0,  "0", "$(SYS)-$(CTA):seq0Ser2-Data-O",  "$(SYS)-$(EOS):Evt-3-Ena-Sel PP",  "$(SYS)-$(CTA):supSer3_0",  "$(TR=0)"} # sequence 0
  # series 3
  {$(SYS)-$(CTA):supSer3_0,  "0", "$(SYS)-$(CTA):seq0Ser3-Data-O",  "$(SYS)-$(EOS):Evt-4-Ena-Sel PP",  "$(SYS)-$(CTA):supSer4_0",  "$(TR=0)"} # sequence 0
  # series 4
  {$(SYS)-$(CTA):supSer4_0,  "0", "$(SYS)-$(CTA):seq0Ser4-Data-O",  "$(SYS)-$(EOS):Evt-5-Ena-Sel PP",  "$(SYS)-$(CTA):supSer5_0",  "$(TR=0)"} # sequence 0
  # series 5
  {$(SYS)-$(CTA):supSer5_0,  "0", "$(SYS)-$(CTA):seq0Ser5-Data-O",  "$(SYS)-$(EOS):Evt-6-Ena-Sel PP",  "$(SYS)-$(CTA):supSer6_0",  "$(TR=0)"} # sequence 0
  # series 6
  {$(SYS)-$(CTA):supSer6_0,  "0", "$(SYS)-$(CTA):seq0Ser6-Data-O",  "$(SYS)-$(EOS):Evt-7-Ena-Sel PP",  "$(SYS)-$(CTA):supSer7_0",  "$(TR=0)"} # sequence 0
  # series 7
  {$(SYS)-$(CTA):supSer7_0,  "0", "$(SYS)-$(CTA):seq0Ser7-Data-O",  "$(SYS)-$(EOS):Evt-8-Ena-Sel PP",  "$(SYS)-$(CTA):supSer8_0",  "$(TR=0)"} # sequence 0
  # series 8
  {$(SYS)-$(CTA):supSer8_0,  "0", "$(SYS)-$(CTA):seq0Ser8-Data-O",  "$(SYS)-$(EOS):Evt-9-Ena-Sel PP",  "$(SYS)-$(CTA):supSer9_0",  "$(TR=0)"} # sequence 0
  # series 9
  {$(SYS)-$(CTA):supSer9_0,  "0", "$(SYS)-$(CTA):seq0Ser9-Data-O",  "$(SYS)-$(EOS):Evt-10-Ena-Sel PP", "$(SYS)-$(CTA):supSer10_0", "$(TR=0)"} # sequence 0
  # series 10
  {$(SYS)-$(CTA):supSer10_0, "0", "$(SYS)-$(CTA):seq0Ser10-Data-O", "$(SYS)-$(EOS):Evt-11-Ena-Sel PP", "$(SYS)-$(CTA):supSer11_0", "$(TR=0)"} # sequence 0
  # series 11
  {$(SYS)-$(CTA):supSer11_0, "0", "$(SYS)-$(CTA):seq0Ser11-Data-O", "$(SYS)-$(EOS):Evt-12-Ena-Sel PP", "$(SYS)-$(CTA):supSer12_0", "$(TR=0)"} # sequence 0
  # series 12
  {$(SYS)-$(CTA):supSer12_0, "0", "$(SYS)-$(CTA):seq0Ser12-Data-O", "$(SYS)-$(EOS):Evt-13-Ena-Sel PP", "$(SYS)-$(CTA):supSer13_0", "$(TR=0)"} # sequence 0
  # series 13
  {$(SYS)-$(CTA):supSer13_0, "0", "$(SYS)-$(CTA):seq0Ser13-Data-O", "$(SYS)-$(EOS):Evt-14-Ena-Sel PP", "$(SYS)-$(CTA):supSer14_0", "$(TR=0)"} # sequence 0
  # series 14
  {$(SYS)-$(CTA):supSer14_0, "0", "$(SYS)-$(CTA):seq0Ser14-Data-O", "$(SYS)-$(EOS):Evt-15-Ena-Sel PP", "$(SYS)-$(CTA):supSer15_0", "$(TR=0)"} # sequence 0
  # series 15
  {$(SYS)-$(CTA):supSer15_0, "0", "$(SYS)-$(CTA):seq0Ser15-Data-O", "$(SYS)-$(EOS):Evt-16-Ena-Sel PP", "$(SYS)-$(CTA):supSer16_0", "$(TR=0)"} # sequence 0
  # series 16
  {$(SYS)-$(CTA):supSer16_0, "0", "$(SYS)-$(CTA):seq0Ser16-Data-O", "$(SYS)-$(EOS):Evt-17-Ena-Sel PP", "$(SYS)-$(CTA):supSer17_0", "$(TR=0)"} # sequence 0
  # series 17
  {$(SYS)-$(CTA):supSer17_0, "0", "$(SYS)-$(CTA):seq0Ser17-Data-O", "$(SYS)-$(EOS):Evt-18-Ena-Sel PP", "$(SYS)-$(CTA):supSer18_0", "$(TR=0)"} # sequence 0
  # series 18
  {$(SYS)-$(CTA):supSer18_0, "0", "$(SYS)-$(CTA):seq0Ser18-Data-O", "$(SYS)-$(EOS):Evt-19-Ena-Sel PP", "$(SYS)-$(CTA):supSer19_0", "$(TR=0)"} # sequence 0
  # series 19
  {$(SYS)-$(CTA):supSer19_0, "0", "$(SYS)-$(CTA):seq0Ser19-Data-O", "$(SYS)-$(EOS):Evt-20-Ena-Sel PP", "",                         "$(TR=0)"} # sequence 0
}

