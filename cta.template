##
# mandatory macros
# ----------------
# SYS
# CTA
#
# optional macros
# ---------------
# LEN = 2048
# TR = 0

# cta -------------------------------------------------------------------------
#
# cta.db provided the records to glue all the elements together.

file cta.db {
  {P="$(SYS)-$(CTA):"}
}

# sequence definition ---------------------------------------------------------
#
# Each sequence consists of a number of series and a sequence controller.

## sequence 0 --------------------------
file seqCtrl.db {
  pattern
  {P,                         FLOAD,                           FINDEX}
  {"$(SYS)-$(CTA):seq0Ctrl-", "$(SYS)-$(CTA):seq0Ser0-Load-I", "$(SYS)-$(CTA):Drv"}
}
file series.db {
  pattern
  {P,                         LENGTH,        FINDEX,                               FLOAD,                            FENABLE}
  {"$(SYS)-$(CTA):seq0Ser0",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser1-Index-I PP",  "$(SYS)-$(CTA):seq0Ser1-Load-I",  "$(SYS)-$(CTA):seq0Ser1-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser1",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser2-Index-I PP",  "$(SYS)-$(CTA):seq0Ser2-Load-I",  "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser2",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser3-Index-I PP",  "$(SYS)-$(CTA):seq0Ser3-Load-I",  "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser3",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser4-Index-I PP",  "$(SYS)-$(CTA):seq0Ser4-Load-I",  "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser4",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser5-Index-I PP",  "$(SYS)-$(CTA):seq0Ser5-Load-I",  "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser5",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser6-Index-I PP",  "$(SYS)-$(CTA):seq0Ser6-Load-I",  "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser6",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser7-Index-I PP",  "$(SYS)-$(CTA):seq0Ser7-Load-I",  "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser7",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser8-Index-I PP",  "$(SYS)-$(CTA):seq0Ser8-Load-I",  "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser8",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser9-Index-I PP",  "$(SYS)-$(CTA):seq0Ser9-Load-I",  "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser9",  "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser10-Index-I PP", "$(SYS)-$(CTA):seq0Ser10-Load-I", "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser10", "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser11-Index-I PP", "$(SYS)-$(CTA):seq0Ser11-Load-I", "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser11", "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser12-Index-I PP", "$(SYS)-$(CTA):seq0Ser12-Load-I", "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser12", "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser13-Index-I PP", "$(SYS)-$(CTA):seq0Ser13-Load-I", "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser13", "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser14-Index-I PP", "$(SYS)-$(CTA):seq0Ser14-Load-I", "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
  {"$(SYS)-$(CTA):seq0Ser14", "$(LEN=2048)", "$(SYS)-$(CTA):seq0Ser15-Index-I PP", "$(SYS)-$(CTA):seq0Ser15-Load-I", "$(SYS)-$(CTA):seq0Ser2-Enable-I PP"}
