#
# mandatory macros:
#  NAME -> name of superposition record
#  IN1  -> PV to read value A from
#  IN2  -> PV to read value B from
#  OUT  -> PV to write result to
#  LNK  -> PV to process next
#
# optional macros:
#  TRA -> used to enable/disable processing (default=disabled)

record(calcout, "$(NAME)") {
  field(INPA, "$(IN1)")
  field(INPB, "$(IN2)")

  field(CALC, "A || B")

  field(OOPT, "Every Time")
  field(DOPT, "Use CALC")
  field(OUT, "$(OUT)")

  field(FLNK, "$(LNK)")

  field(TPRO, "$(TRA=0)")
}

