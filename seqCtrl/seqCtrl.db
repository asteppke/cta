##
# Mandatory macros
#  P      -> used as prefix for all record names
#  FLOAD  -> used to forward load command
#  FINDEX -> used to forward index command
#  PULSE_ID_READ -> name of record to read pulse id from
#
# Optional macros
#  FRUNNING -> used to forward running command (default="")
#  TRA      -> used to control tracing (default=0)

record(bo, "$(P)Start-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "@START_SIG")

  field(TPRO, "$(TRA=0)")
}

record(bo, "$(P)Stop-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "@STOP_SIG")

  field(TPRO, "$(TRA=0)")
}

record(ao, "$(P)SOS-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S0")

  field(OMSL, "closed_loop")
  field(DOL, "$(PULSE_ID_READ)")

  field(TPRO, "$(TRA=0)")

}

record(longout, "$(P)Length-I") {

  field(PINI, "YES")
  field(DOL, "0")

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S0")

  field(TPRO, "$(TRA=0)")

}

record(longout, "$(P)Cycles-I") {

  field(PINI, "YES")
  field(DOL, "1")

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S1")

  field(TPRO, "$(TRA=0)")

}

# Supported values
# 0 = start immediately
# 1 = start modulo
record(longout, "$(P)SCfgMode-I") {

  field(DESC, "Mode of start configuration")

  field(PINI, "YES")
  field(DOL, "0")

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S2")

  field(TPRO, "$(TRA=0)")

}

record(longout, "$(P)SCfgModDivisor-I") {

  field(DESC, "Divisor of modulo start configuration")

  field(PINI, "YES")
  field(DOL, "1")

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S3")

  field(TPRO, "$(TRA=0)")

}

record(longout, "$(P)SCfgModOffset-I") {

  field(DESC, "Offset of modulo start configuration")

  field(PINI, "YES")
  field(DOL, "0")

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S4")

  field(TPRO, "$(TRA=0)")

}

record(longin, "$(P)Index-O") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S0")

  field(SCAN, "I/O Intr")

  field(PRIO, "HIGH")

  field(TPRO, "$(TRA=0)")

}

record(longin, "$(P)IsRunning-O") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S3")

  field(SCAN, "I/O Intr")

  field(FLNK, "$(FRUNNING="")")

  field(PRIO, "HIGH")

  field(TPRO, "$(TRA=0)")

}

record(longin, "$(P)IsEnabled-O") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S4")

  field(SCAN, "I/O Intr")

  field(PRIO, "HIGH")

  field(TPRO, "$(TRA=0)")

}

record(longin, "$(P)Load_") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S1")

  field(SCAN, "I/O Intr")

  field(FLNK, "$(FLOAD)")

  field(PRIO, "HIGH")

  field(TPRO, "$(TRA=0)")

}

record(longin, "$(P)SOP_") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S2")

  field(SCAN, "I/O Intr")

  field(FLNK, "$(FINDEX)")

  field(PRIO, "HIGH")

  field(TPRO, "$(TRA=0)")

}

record(ai, "$(P)StartedAt-O") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S0")

  field(SCAN, "I/O Intr")

  field(PRIO, "HIGH")

  field(TPRO, "$(TRA=0)")

}

