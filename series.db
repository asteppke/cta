##
# mandatory macros
#   P       Prefix to build record name
#   LENGTH  Number of elements in series
# optional macros
#   TRA     Record processing tracing enable/disable
#   FPLAY   Forward play processing command to other play record

record(waveform, "$(P)-I") {
  field(NELM, "$(LENGTH)")
  field(FTVL, "LONG")

  field(TPRO, "$(TRA=0)")
}

record(fanout, "$(P)-Load") {

  field(SELM, "All")

  field(LNK1, "$(P)Play")
  field(LNK2, "$(FPLAY="")")

  field(TPRO, "$(TRA=0)")
}

record(dfanout, "$(P)-Index") {

  field(OUTA, "$(P)Pick.INDX PP")
  field(OUTB, "$(FPICK="")")

  field(TPRO, "$(TRA=0)")
}

record(waveform, "$(P)Play") {

  field(NELM, "$(LENGTH)")
  field(FTVL, "LONG")

  field(INP, "$(P)-I")

  field(TPRO, "$(TRA=0)")
}

record(subArray, "$(P)Pick") {

  field(INP, "$(P)Play.VAL")

  field(MALM, "$(LENGTH)")
  field(NELM, "1")
  field(FTVL, "LONG")

  field(FLNK, "$(P)-O")

  field(TPRO, "$(TRA=0)")
}

record(longout, "$(P)-O") {

  field(OMSL, "closed_loop")
  field(DOL, "$(P)Pick")

  field(TPRO, "$(TRA=0)")
}

