##
# mandatory macros
# ----------------
# DN     -> device name
# LENGTH -> max length for series
# EOS    -> device name used to reference EOS PVs
#
# Optional macros:
#  TRA -> enable (1) or disable (0) processing tracing
#
# optional macros
# ---------------
# LEN = 2048
# TR = 0

# cta -------------------------------------------------------------------------
#
# cta.db provided the records to glue all the elements together.

file cta.db {
  {P="$(DN):", LENGTH="$(LEN=2048)", SOS1_FWD_HOOK="$(DN):Seq1PerfStart-Cmd", SOS2_FWD_HOOK="$(DN):Seq2PerfStart-Cmd"}
}

# performance -----------------------------------------------------------------
#
# performance.db contains records to provide a performance measurement
# functionality.

file performance.db {
  {P="$(DN):", SEQNUM="1"}
  {P="$(DN):", SEQNUM="2"}
}

# sequence definition ---------------------------------------------------------
#
# Each sequence consists of a number of series and a sequence controller.

## sequence 0 --------------------------
file seqCtrl.db {
  pattern
  {P,                 FLOAD,                   FINDEX,      PULSE_ID_READ}
  {"$(DN):seq0Ctrl-", "$(DN):seq0Ser0-Load-I", "$(DN):Drv", "$(PIR)"}
}

file series.db {
  pattern
  {P,                 LENGTH,        FINDEX,                       FLOAD,                    FENABLE}
  {"$(DN):seq0Ser0",  "$(LEN=2048)", "$(DN):seq0Ser1-Index-I PP",  "$(DN):seq0Ser1-Load-I",  "$(DN):seq0Ser1-Enable-I PP"}
