# Mandatory macros:
# P      -> used to build prefix for record names
# LENGTH -> max length for series
# EOS    -> device name used to reference EOS PVs
#
# Optional macros:
#  TRA -> enable (1) or disable (0) processing tracing

record(bi, "$(P)SOS1") {

  field(DTYP, "EVG START OF SEQ")
  field(INP, "#C S1 @EVG1")

  field(SCAN, "I/O Intr")

  field(PRIO, "HIGH")

  field(FLNK, "$(P)CurrSeq")

  field(TPRO, "$(TRA=0)")
}

record(bi, "$(P)SOS2") {

  field(DTYP, "EVG START OF SEQ")
  field(INP, "#C S2 @EVG1")

  field(SCAN, "I/O Intr")

  field(PRIO, "HIGH")

  field(FLNK, "$(P)CurrSeq")

  field(TPRO, "$(TRA=0)")
}

record(calc, "$(P)CurrSeq") {

  field(INPA, "$(P)SOS1.PACT")
  
  field(CALC, "A ? 1 : 2")

  field(FLNK, "$(P)seq0Ctrl-SOS-I")

  field(TPRO, "$(TRA=0)")
}

record(fanout, "$(P)Drv") {

  field(LNK1, "$(P)DrvSeq0")
  field(LNK2, "$(P)DrvSeq1")
  field(LNK3, "$(P)supSer0_0")
  field(LNK4, "$(P)Seq1Trig")
  field(LNK5, "$(P)Seq2Trig")

  field(TPRO, "$(TRA=0)")
}

record(dfanout, "$(P)DrvSeq0") {

  field(OMSL, "closed_loop")

  field(DOL, "$(P)seq0Ctrl-IsRunning-O PP")

  field(OUTA, "$(P)seq0Ser0-Enable-I PP")

  field(TPRO, "$(TRA=0)")
}

record(dfanout, "$(P)DrvSeq1") {

  field(OMSL, "closed_loop")

  field(DOL, "$(P)seq0Ctrl-Index-O PP")

  field(OUTA, "$(P)seq0Ser0-Index-I PP")

  field(TPRO, "$(TRA=0)")
}

record(fanout, "$(P)Seq1Trig") {

  field(DISV, "2")
  field(SDIS, "$(P)CurrSeq")

  field(LNK1, "$(EOS):Seq1-Do-I")

  field(TPRO, "$(TRA=0)")
}

record(fanout, "$(P)Seq2Trig") {

  field(DISV, "1")
  field(SDIS, "$(P)CurrSeq")

  field(LNK1, "$(EOS):Seq2-Do-I")

  field(TPRO, "$(TRA=0)")
}

record(longin, "$(P)SerMaxLen") {

  field(PINI, "YES")

  field(INP, "$(LENGTH)")

  field(TPRO, "$(TRA=0)")

}

