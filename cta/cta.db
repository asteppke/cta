# Mandatory macros:
# P      -> used to build prefix for record names
# LENGTH -> max length for series
# EOS    -> device name used to reference EOS PVs
#
# Optional macros:
#  SOS1_FWD_HOOK -> This is a hook to forward processing when start of sequence
#                   interrupt of sequence 1 has occured.
#  SOS2_FWD_HOOK -> This is a hook to forward processing when start of sequence
#                   interrupt of sequence 2 has occured.
#  TRA -> enable (1) or disable (0) processing tracing

record(bi, "$(P)SOS1") {
  field(DTYP, "EVG START OF SEQ")
  field(INP,  "#C0 S1 @$(DEVICE)")
  field(SCAN, "I/O Intr")
  field(PRIO, "HIGH")
  field(FLNK, "$(P)SOS1Hook_")
  field(TPRO, "$(TRA=0)")
}

record(fanout, "$(P)SOS1Hook_") {
  field(LNK1, "$(P)supSer0_0")
  field(LNK2, "$(P)seq0Ctrl-SeqCtrl_")
  field(LNK3, "$(EOS):Seq1-Do-I")
}

record(bi, "$(P)SOS2") {
  field(DTYP, "EVG START OF SEQ")
  field(INP,  "#C0 S2 @$(DEVICE)")
  field(SCAN, "I/O Intr")
  field(PRIO, "HIGH")
  field(FLNK, "$(P)SOS2Hook_")
  field(TPRO, "$(TRA=0)")
}

record(fanout, "$(P)SOS2Hook_") {
  field(LNK1, "$(P)supSer0_0")
  field(LNK2, "$(P)seq0Ctrl-SeqCtrl_")
  field(LNK3, "$(EOS):Seq2-Do-I")
}
