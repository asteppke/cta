###
# Mandatory macros
#  P      -> used as prefix for all record names
#  FLOAD  -> used to forward load command
#  PIR    -> name of record to read pulse id from
#

##################################
# State machine input parameters
##################################

### Start
record(bo, "$(P)Start-I") {
}

### Stop
record(bo, "$(P)Stop-I") {
}

### Sequence length 
record(longout, "$(P)Length-I") {
    field(PINI, "YES")
    field(DOL, "0")
    field(FLNK, "$(P)LoadSeqPending_")
}
# detect modification of sequence
record(calcout, "$(P)LoadSeqPending_") {
    field(CALC, "1")
    field(OUT, "$(P)LoadSeqPending-I PP")
}
record(bo, "$(P)LoadSeqPending-I") {
    field(DESC, "CTA seq. mpodified, load pending")
}

### Maximum length of a sequence
record(longout, "$(DN):SerMaxLen-O") {
    field(VAL, "$(LENGTH)")
}

### Number of repetitions
record(longout, "$(P)Cycles-I") {
    field(PINI, "YES")
}

### Sequence Modulo for divisor
# Supported values
# 0 = start immediately
# 1 = start modulo
record(longout, "$(P)SCfgMode-I") {
    field(DESC, "Mode of start configuration")
    field(PINI, "YES")
    field(DOL, "0")

}

### Sequence divisor
record(longout, "$(P)SCfgModDivisor-I") {
    field(DESC, "Divisor of modulo start configuration")
    field(PINI, "YES")
    field(DOL, "1")
}

### Sequence offset 
record(longout, "$(P)SCfgModOffset-I") {
    field(DESC, "Offset of modulo start configuration")
    field(PINI, "YES")
    field(DOL, "0")
}

##################################
# State machine outputs control
##################################

### Load sequence 
record(bo, "$(P)LoadSeq_") {
    field(PINI, "YES")
    field(FLNK, "$(P)LoadSeq__")
}
record(calcout, "$(P)LoadSeq__") {
    field(INPA, "$(P)LoadSeq_")
    field(CALC, "A")
    field(OOPT, "When Non-zero")
    field(OUT,  "$(FLOAD) PP")
    field(PRIO, "HIGH")
}

##################################
# State machine outputs states
##################################

### Sequence current index 
record(longout, "$(P)Index-O") {
    field(PRIO, "HIGH")
}

### Sequence running state
record(longout, "$(P)IsRunning-O") {
    field(PRIO, "HIGH")
}

### Pulse ID at start of sequence  
record(int64in, "$(P)StartedAt-O") {
    field(PRIO, "HIGH")
}

##################################
# State machine 
##################################

record(aSub, "$(P)SeqCtrl_") {
    field(SNAM, "cta_state_machine")
    field(PRIO, "HIGH")

    # Input
    field(INPA, "$(P)Start-I")               # CTA sequence start button 
    field(FTA,  "USHORT")
    field(INPB, "$(P)Stop-I")                # CTA sequence stop button 
    field(FTB,  "USHORT")
    field(INPC, "$(DN_SER0)Index-I")         # CTA sequence index 
    field(FTC,  "ULONG")
    field(INPD, "$(P)IsRunning-O")           # CTA sequence running 
    field(FTD,  "ULONG")
    field(INPE, "$(PIR)")                    # Current Pulse ID
    field(FTE,  "UINT64")
    field(INPF, "$(P)StartedAt-O")           # Pulse ID at which the sequence started
    field(FTF,  "UINT64")
    field(INPG, "$(P)Length-I")              # CTA sequence length
    field(FTG,  "ULONG")
    field(INPH, "$(P)Cycles-I")              # CTA sequence number of cycles
    field(FTH,  "ULONG")
    field(INPI, "$(P)SCfgMode-I")            # Start sequence configuration - Mode
    field(FTI,  "ULONG")
    field(INPJ, "$(P)SCfgModDivisor-I")      # Start sequence configuration - Divisor
    field(FTJ,  "ULONG")
    field(INPK, "$(P)SCfgModOffset-I")       # Start sequence configuration - Offset
    field(FTK,  "ULONG")
    field(INPL, "$(P)LoadSeqPending-I")      # CTA sequence load pending flag
    field(FTL,  "USHORT")

    # Output
    field(OUTA, "$(P)Start-I PP")
    field(FTVA, "USHORT")
    field(OUTB, "$(P)Stop-I PP")
    field(FTVB, "USHORT")
    field(OUTC, "$(DN_SER0)Index-I PP")      # Index of Seq0 Ser0, propagated to all series via series.db
    field(FTVC, "ULONG")
    field(OUTD, "$(P)Index-O PP")            # Global index for CTA
    field(FTVD, "ULONG")
    field(OUTE, "$(P)IsRunning-O PP")        # Running state 
    field(FTVE, "ULONG")
    field(OUTF, "$(P)StartedAt-O PP")        # PID when sequence started
    field(FTVF, "UINT64")
    field(OUTG, "$(P)LoadSeq_ PP")           # Record to load CTA sequence
    field(FTVG, "USHORT")
    field(OUTH, "$(P)LoadSeqPending-I NPP")  # CTA sequence load pending flag
    field(FTVH,  "USHORT")
    field(OUTI, "$(DN_SER0)Enable-I PP")     # Enable Seq0, Ser0, propagated to all series
    field(FTVI, "USHORT")
}
