##
# Mandatory macros
# ----------------
# P
# FLOAD
# FINDEX
#
# Optional macros
# ---------------
# TRA (default=0)

#record(bi, "$(P)SOS-Trigger") {
#  field(DTYP, "EVG START OF SEQ")
#  field(INP,  "#C S1 @EVG0")
#  field(SCAN, "I/O Intr")
#  field(FLNK, "$(P)SOS-I")
#  field(PRIO, "HIGH")
#}

record(bo, "$(P)Start-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#@START_SIG")

  field(TPRO, "$(TRA=0)")
}

record(bo, "$(P)Stop-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#@STOP_SIG")

  field(TPRO, "$(TRA=0)")
}

record(ao, "$(P)SOS-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S0")

  field(TPRO, "$(TRA=0)")

}

record(bo, "$(P)SOP-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#@SOP_SIG")

  field(TPRO, "$(TRA=0)")
}

record(longout, "$(P)Length-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S0")

  field(TPRO, "$(TRA=0)")

}

record(longout, "$(P)Cycles-I") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S1")

  field(TPRO, "$(TRA=0)")

}

record(longin, "$(P)Index") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S0")

  field(TPRO, "$(TRA=0)")

}

record(longin, "$(P)SOP") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S2")

  field(SCAN, "I/O Intr")

  field(FLNK, "$(P)Proc")

  field(TPRO, "$(TRA=0)")

}

record(fanout, "$(P)Proc") {

#  field(LNK1, "$(P)Index") # read index
#  field(LNK2, "$(P)DriveIndex") # process series
#  field(LNK3, "SYS-$(CTA):supSer0_0") # process superposition

  field(TPRO, "$(TRA=0)")

}

record(calcout, "$(P)DriveIndex") {

  field(INPA, "$(P)Index")

  field(CALC, "A")

  field(OOPT, "Every Time")
  field(DOPT, "Use CALC")
  field(OUT, "$(FINDEX)")

  field(TPRO, "$(TRA=0)")

}

record(longin, "$(P)Load") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S1")

  field(SCAN, "I/O Intr")

  field(FLNK, "$(FLOAD)")

  field(TPRO, "$(TRA=0)")

}
