##

record(bo, "$(P)Start") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#@START_SIG")
}

record(bo, "$(P)Stop") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#@STOP_SIG")
}

record(ao, "$(P)SOS") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S0")

  field(FLNK, "$(P)SeqCtrl")
}

record(aSub, "$(P)SeqCtrl") {

  field(INPA, "0") # start/stop command
  field(FTA, "LONG")

  field(INPB, "0") # SOS (start of sequence) command
  field(FTB, "LONG")

  field(INAM, "AsubSeqCtrl_init")
  field(SNAM, "AsubSeqCtrl_process")

}

record(longin, "$(P)Index") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S0")

  field(SCAN, "Event")
  field(EVNT, "12")
}

