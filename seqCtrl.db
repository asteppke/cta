##

record(bo, "$(P)Start") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#@START_SIG")
}

record(bo, "$(P)Stop") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#@STOP_SIG")
}

record(ao, "$(P)SOS") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S0")

}

record(longout, "$(P)Length") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S0")

}

record(longout, "$(P)Cycles") {

  field(DTYP, "DevSeqCtrl")
  field(OUT, "#C0 S1")

}

record(longin, "$(P)Index") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S0")

  field(SCAN, "I/O Intr")
}

record(longin, "$(P)Load") {

  field(DTYP, "DevSeqCtrl")
  field(INP, "#C0 S1")

  field(SCAN, "I/O Intr")
}

